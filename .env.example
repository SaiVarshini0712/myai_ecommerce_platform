# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection
# Replace with your actual MongoDB Atlas connection string in your local .env file
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/fashion_marketplace?retryWrites=true&w=majority

# Authentication Security
# Use a long, random string for your local secret key
JWT_SECRET=your_super_secret_jwt_token_key_here
JWT_EXPIRES_IN=7d

# Vendor & Marketplace Logic Settings
PLATFORM_COMMISSION_RATE=0.10

# AI Configuration (Optional / Next Steps)
# If you integrate an external LLM API later
AI_SERVICE_API_KEY=your_ai_platform_api_key_here
